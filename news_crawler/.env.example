# ============================================================
# Food Oil News Crawler — Environment Variables
# Copy this file to .env and fill in your API keys.
# Never commit .env to version control.
# ============================================================

# --- Media Cloud (PRIMARY recommended source) ---
# Register at https://search.mediacloud.org/user/profile (free academic access)
# Then: python -m crawler --config config/config_mediacloud.yaml mc-collections
#       to list Indian collection IDs, then update config_mediacloud.yaml.
MEDIACLOUD_API_KEY=your_mediacloud_api_key_here

# --- Google Custom Search Engine ---
# Create a CSE at https://programmablesearchengine.google.com/
# Get API key at https://console.developers.google.com/
GOOGLE_CSE_KEY=your_google_cse_api_key_here
GOOGLE_CSE_CX=your_search_engine_id_here

# --- Bing Web Search API ---
# Get from Azure Portal → Cognitive Services → Bing Search v7
BING_API_KEY=your_bing_api_key_here

# --- SerpAPI ---
# Get from https://serpapi.com/
SERPAPI_KEY=your_serpapi_key_here

# --- Anthropic API (for LLM-based NLP extraction, optional) ---
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
